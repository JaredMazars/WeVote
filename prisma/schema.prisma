// WeVote Prisma Schema
// Version: 1.0
// Date: December 7, 2025
// Database: PostgreSQL 14+

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// ORGANIZATIONS & USERS
// =====================================================

model Organization {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  String   @db.VarChar(255)
  domain                String?  @unique @db.VarChar(255)
  logoUrl               String?  @map("logo_url") @db.Text
  primaryColor          String   @default("#0072CE") @map("primary_color") @db.VarChar(7)
  secondaryColor        String   @default("#171C8F") @map("secondary_color") @db.VarChar(7)
  subscriptionTier      String   @default("startup") @map("subscription_tier") @db.VarChar(50)
  maxVoters             Int      @default(100) @map("max_voters")
  maxMeetingsPerYear    Int      @default(5) @map("max_meetings_per_year")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  users                 User[]
  agmSessions           AgmSession[]
  auditLogs             AuditLog[]
  emailTemplates        EmailTemplate[]
  votingPatterns        VotingPattern[]

  @@map("organizations")
}

model User {
  id                      String    @id @default(uuid()) @db.Uuid
  organizationId          String    @map("organization_id") @db.Uuid
  email                   String    @unique @db.VarChar(255)
  passwordHash            String?   @map("password_hash") @db.Text
  firstName               String    @map("first_name") @db.VarChar(100)
  lastName                String    @map("last_name") @db.VarChar(100)
  avatarUrl               String?   @map("avatar_url") @db.Text
  phoneNumber             String?   @map("phone_number") @db.VarChar(20)
  role                    String    @default("voter") @db.VarChar(50)
  languagePreference      String    @default("en") @map("language_preference") @db.VarChar(10)
  isActive                Boolean   @default(true) @map("is_active")
  isEmailVerified         Boolean   @default(false) @map("is_email_verified")
  emailVerificationToken  String?   @map("email_verification_token") @db.Text
  passwordResetToken      String?   @map("password_reset_token") @db.Text
  passwordResetExpires    DateTime? @map("password_reset_expires") @db.Timestamptz(6)
  lastLoginAt             DateTime? @map("last_login_at") @db.Timestamptz(6)
  lastLoginIp             String?   @map("last_login_ip") @db.Inet
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  oauthAccounts           OAuthAccount[]
  twoFactorAuth           TwoFactorAuth?
  userSessions            UserSession[]
  employeeProfile         EmployeeProfile?
  candidatesNominated     Candidate[]
  candidateVotes          CandidateVote[]
  resolutionVotes         ResolutionVote[]
  proxiesGiven            ProxyAssignment[] @relation("ProxiesPrincipal")
  proxiesReceived         ProxyAssignment[] @relation("ProxiesHolder")
  voteAllocations         VoteAllocation[]
  emailNotifications      EmailNotification[]
  smsNotifications        SmsNotification[]
  whatsappNotifications   WhatsAppNotification[]
  auditLogs               AuditLog[]
  qaQuestions             QAQuestion[]
  qaAnswers               QAAnswer[]
  qaUpvotes               QAUpvote[]
  meetingAttendance       MeetingAttendance[]
  votingPattern           VotingPattern?
  agmSessionsCreated      AgmSession[]

  @@map("users")
}

model OAuthAccount {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  provider          String   @db.VarChar(50)
  providerAccountId String   @map("provider_account_id") @db.VarChar(255)
  accessToken       String?  @map("access_token") @db.Text
  refreshToken      String?  @map("refresh_token") @db.Text
  tokenExpiresAt    DateTime? @map("token_expires_at") @db.Timestamptz(6)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model TwoFactorAuth {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @unique @map("user_id") @db.Uuid
  secret        String    @db.Text
  backupCodes   String[]  @map("backup_codes")
  isEnabled     Boolean   @default(false) @map("is_enabled")
  enabledAt     DateTime? @map("enabled_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor_auth")
}

model UserSession {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  token           String   @unique @db.Text
  deviceInfo      Json?    @map("device_info") @db.JsonB
  ipAddress       String?  @map("ip_address") @db.Inet
  isTrustedDevice Boolean  @default(false) @map("is_trusted_device")
  expiresAt       DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  lastActivityAt  DateTime @default(now()) @map("last_activity_at") @db.Timestamptz(6)

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model EmployeeProfile {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @unique @map("user_id") @db.Uuid
  employeeId   String?   @map("employee_id") @db.VarChar(50)
  department   String?   @db.VarChar(100)
  position     String?   @db.VarChar(100)
  managerId    String?   @map("manager_id") @db.Uuid
  hireDate     DateTime? @map("hire_date") @db.Date
  bio          String?   @db.Text
  skills       String[]
  achievements String[]
  location     String?   @db.VarChar(255)
  timezone     String    @default("Africa/Johannesburg") @db.VarChar(50)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("employee_profiles")
}

// =====================================================
// VOTING SYSTEM
// =====================================================

model AgmSession {
  id                  String    @id @default(uuid()) @db.Uuid
  organizationId      String    @map("organization_id") @db.Uuid
  title               String    @db.VarChar(255)
  description         String?   @db.Text
  meetingType         String    @default("annual") @map("meeting_type") @db.VarChar(50)
  scheduledStartTime  DateTime  @map("scheduled_start_time") @db.Timestamptz(6)
  scheduledEndTime    DateTime  @map("scheduled_end_time") @db.Timestamptz(6)
  actualStartTime     DateTime? @map("actual_start_time") @db.Timestamptz(6)
  actualEndTime       DateTime? @map("actual_end_time") @db.Timestamptz(6)
  status              String    @default("scheduled") @db.VarChar(50)
  quorumRequired      Int       @default(50) @map("quorum_required")
  quorumMet           Boolean   @default(false) @map("quorum_met")
  meetingUrl          String?   @map("meeting_url") @db.Text
  recordingUrl        String?   @map("recording_url") @db.Text
  createdBy           String?   @map("created_by") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator             User?        @relation(fields: [createdBy], references: [id])
  
  candidates          Candidate[]
  resolutions         Resolution[]
  voteAllocations     VoteAllocation[]
  proxyAssignments    ProxyAssignment[]
  candidateVotes      CandidateVote[]
  resolutionVotes     ResolutionVote[]
  meetingDocuments    MeetingDocument[]
  qaQuestions         QAQuestion[]
  auditLogs           AuditLog[]
  meetingAttendance   MeetingAttendance[]
  reportHistory       ReportHistory[]

  @@map("agm_sessions")
}

model MeetingDocument {
  id            String   @id @default(uuid()) @db.Uuid
  agmSessionId  String   @map("agm_session_id") @db.Uuid
  title         String   @db.VarChar(255)
  fileUrl       String   @map("file_url") @db.Text
  fileType      String?  @map("file_type") @db.VarChar(50)
  fileSizeBytes BigInt?  @map("file_size_bytes")
  version       Int      @default(1)
  uploadedBy    String?  @map("uploaded_by") @db.Uuid
  isPublic      Boolean  @default(false) @map("is_public")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  agmSession    AgmSession @relation(fields: [agmSessionId], references: [id], onDelete: Cascade)

  @@map("meeting_documents")
}

model Candidate {
  id              String    @id @default(uuid()) @db.Uuid
  agmSessionId    String    @map("agm_session_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  position        String    @db.VarChar(100)
  department      String?   @db.VarChar(100)
  bio             String?   @db.Text
  manifesto       String?   @db.Text
  photoUrl        String?   @map("photo_url") @db.Text
  nominationDate  DateTime  @default(now()) @map("nomination_date") @db.Timestamptz(6)
  isApproved      Boolean   @default(false) @map("is_approved")
  approvedBy      String?   @map("approved_by") @db.Uuid
  approvedAt      DateTime? @map("approved_at") @db.Timestamptz(6)
  displayOrder    Int       @default(0) @map("display_order")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  agmSession      AgmSession @relation(fields: [agmSessionId], references: [id], onDelete: Cascade)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  votes           CandidateVote[]
  proxyInstructions ProxyInstruction[]

  @@map("candidates")
}

model Resolution {
  id                  String    @id @default(uuid()) @db.Uuid
  agmSessionId        String    @map("agm_session_id") @db.Uuid
  title               String    @db.VarChar(500)
  description         String    @db.Text
  category            String?   @db.VarChar(100)
  votingRequirement   String    @default("ordinary") @map("voting_requirement") @db.VarChar(50)
  requiredPercentage  Decimal   @default(50.00) @map("required_percentage") @db.Decimal(5, 2)
  financialImpact     Decimal?  @map("financial_impact") @db.Decimal(15, 2)
  effectiveDate       DateTime? @map("effective_date") @db.Date
  proposerId          String?   @map("proposer_id") @db.Uuid
  seconderId          String?   @map("seconder_id") @db.Uuid
  displayOrder        Int       @default(0) @map("display_order")
  isApproved          Boolean   @default(false) @map("is_approved")
  approvedBy          String?   @map("approved_by") @db.Uuid
  approvedAt          DateTime? @map("approved_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  agmSession          AgmSession @relation(fields: [agmSessionId], references: [id], onDelete: Cascade)
  
  votes               ResolutionVote[]
  proxyInstructions   ProxyInstruction[]

  @@map("resolutions")
}

model VoteAllocation {
  id             String   @id @default(uuid()) @db.Uuid
  agmSessionId   String   @map("agm_session_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  allocatedVotes Int      @default(1) @map("allocated_votes")
  reason         String?  @db.Text
  allocatedBy    String?  @map("allocated_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  agmSession     AgmSession @relation(fields: [agmSessionId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agmSessionId, userId])
  @@map("vote_allocations")
}

model ProxyAssignment {
  id             String    @id @default(uuid()) @db.Uuid
  agmSessionId   String    @map("agm_session_id") @db.Uuid
  principalId    String    @map("principal_id") @db.Uuid
  proxyHolderId  String    @map("proxy_holder_id") @db.Uuid
  proxyType      String    @db.VarChar(50)
  voteWeight     Decimal   @default(100.00) @map("vote_weight") @db.Decimal(5, 2)
  validFrom      DateTime  @default(now()) @map("valid_from") @db.Timestamptz(6)
  validUntil     DateTime? @map("valid_until") @db.Timestamptz(6)
  isActive       Boolean   @default(true) @map("is_active")
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  agmSession     AgmSession @relation(fields: [agmSessionId], references: [id], onDelete: Cascade)
  principal      User       @relation("ProxiesPrincipal", fields: [principalId], references: [id], onDelete: Cascade)
  proxyHolder    User       @relation("ProxiesHolder", fields: [proxyHolderId], references: [id], onDelete: Cascade)
  
  instructions   ProxyInstruction[]
  candidateVotes CandidateVote[]
  resolutionVotes ResolutionVote[]

  @@map("proxy_assignments")
}

model ProxyInstruction {
  id                 String   @id @default(uuid()) @db.Uuid
  proxyAssignmentId  String   @map("proxy_assignment_id") @db.Uuid
  candidateId        String?  @map("candidate_id") @db.Uuid
  resolutionId       String?  @map("resolution_id") @db.Uuid
  instruction        String   @db.VarChar(50)
  notes              String?  @db.Text
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  proxyAssignment    ProxyAssignment @relation(fields: [proxyAssignmentId], references: [id], onDelete: Cascade)
  candidate          Candidate?      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  resolution         Resolution?     @relation(fields: [resolutionId], references: [id], onDelete: Cascade)

  @@map("proxy_instructions")
}

model CandidateVote {
  id                 String   @id @default(uuid()) @db.Uuid
  agmSessionId       String   @map("agm_session_id") @db.Uuid
  candidateId        String   @map("candidate_id") @db.Uuid
  voterId            String   @map("voter_id") @db.Uuid
  voteType           String   @map("vote_type") @db.VarChar(50)
  proxyAssignmentId  String?  @map("proxy_assignment_id") @db.Uuid
  voteWeight         Decimal  @default(1.00) @map("vote_weight") @db.Decimal(5, 2)
  votedAt            DateTime @default(now()) @map("voted_at") @db.Timestamptz(6)
  ipAddress          String?  @map("ip_address") @db.Inet
  userAgent          String?  @map("user_agent") @db.Text

  agmSession         AgmSession       @relation(fields: [agmSessionId], references: [id], onDelete: Cascade)
  candidate          Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  voter              User             @relation(fields: [voterId], references: [id], onDelete: Cascade)
  proxyAssignment    ProxyAssignment? @relation(fields: [proxyAssignmentId], references: [id])

  @@unique([agmSessionId, candidateId, voterId, proxyAssignmentId])
  @@map("candidate_votes")
}

model ResolutionVote {
  id                 String   @id @default(uuid()) @db.Uuid
  agmSessionId       String   @map("agm_session_id") @db.Uuid
  resolutionId       String   @map("resolution_id") @db.Uuid
  voterId            String   @map("voter_id") @db.Uuid
  vote               String   @db.VarChar(20)
  voteType           String   @map("vote_type") @db.VarChar(50)
  proxyAssignmentId  String?  @map("proxy_assignment_id") @db.Uuid
  voteWeight         Decimal  @default(1.00) @map("vote_weight") @db.Decimal(5, 2)
  votedAt            DateTime @default(now()) @map("voted_at") @db.Timestamptz(6)
  ipAddress          String?  @map("ip_address") @db.Inet
  userAgent          String?  @map("user_agent") @db.Text

  agmSession         AgmSession       @relation(fields: [agmSessionId], references: [id], onDelete: Cascade)
  resolution         Resolution       @relation(fields: [resolutionId], references: [id], onDelete: Cascade)
  voter              User             @relation(fields: [voterId], references: [id], onDelete: Cascade)
  proxyAssignment    ProxyAssignment? @relation(fields: [proxyAssignmentId], references: [id])

  @@unique([agmSessionId, resolutionId, voterId, proxyAssignmentId])
  @@map("resolution_votes")
}

// =====================================================
// ENGAGEMENT & COMMUNICATION
// =====================================================

model QAQuestion {
  id            String    @id @default(uuid()) @db.Uuid
  agmSessionId  String    @map("agm_session_id") @db.Uuid
  userId        String?   @map("user_id") @db.Uuid
  question      String    @db.Text
  isAnonymous   Boolean   @default(false) @map("is_anonymous")
  status        String    @default("pending") @db.VarChar(50)
  upvotes       Int       @default(0)
  moderatedBy   String?   @map("moderated_by") @db.Uuid
  moderatedAt   DateTime? @map("moderated_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  agmSession    AgmSession  @relation(fields: [agmSessionId], references: [id], onDelete: Cascade)
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  answers       QAAnswer[]
  qaUpvotes     QAUpvote[]

  @@map("qa_questions")
}

model QAAnswer {
  id          String   @id @default(uuid()) @db.Uuid
  questionId  String   @map("question_id") @db.Uuid
  answeredBy  String?  @map("answered_by") @db.Uuid
  answer      String   @db.Text
  answeredAt  DateTime @default(now()) @map("answered_at") @db.Timestamptz(6)

  question    QAQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerer    User?      @relation(fields: [answeredBy], references: [id])

  @@map("qa_answers")
}

model QAUpvote {
  id         String   @id @default(uuid()) @db.Uuid
  questionId String   @map("question_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  question   QAQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([questionId, userId])
  @@map("qa_upvotes")
}

model EmailNotification {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  templateName String    @map("template_name") @db.VarChar(100)
  subject      String    @db.VarChar(500)
  bodyHtml     String    @map("body_html") @db.Text
  bodyText     String?   @map("body_text") @db.Text
  status       String    @default("pending") @db.VarChar(50)
  scheduledFor DateTime  @default(now()) @map("scheduled_for") @db.Timestamptz(6)
  sentAt       DateTime? @map("sent_at") @db.Timestamptz(6)
  errorMessage String?   @map("error_message") @db.Text
  retryCount   Int       @default(0) @map("retry_count")
  metadata     Json?     @db.JsonB
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_notifications")
}

model SmsNotification {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  phoneNumber       String    @map("phone_number") @db.VarChar(20)
  message           String    @db.Text
  status            String    @default("pending") @db.VarChar(50)
  scheduledFor      DateTime  @default(now()) @map("scheduled_for") @db.Timestamptz(6)
  sentAt            DateTime? @map("sent_at") @db.Timestamptz(6)
  errorMessage      String?   @map("error_message") @db.Text
  retryCount        Int       @default(0) @map("retry_count")
  provider          String?   @db.VarChar(50)
  providerMessageId String?   @map("provider_message_id") @db.VarChar(255)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sms_notifications")
}

model WhatsAppNotification {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  phoneNumber       String    @map("phone_number") @db.VarChar(20)
  message           String    @db.Text
  status            String    @default("pending") @db.VarChar(50)
  scheduledFor      DateTime  @default(now()) @map("scheduled_for") @db.Timestamptz(6)
  sentAt            DateTime? @map("sent_at") @db.Timestamptz(6)
  errorMessage      String?   @map("error_message") @db.Text
  retryCount        Int       @default(0) @map("retry_count")
  providerMessageId String?   @map("provider_message_id") @db.VarChar(255)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("whatsapp_notifications")
}

// =====================================================
// AUDIT & COMPLIANCE
// =====================================================

model AuditLog {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String?   @map("organization_id") @db.Uuid
  agmSessionId   String?   @map("agm_session_id") @db.Uuid
  userId         String?   @map("user_id") @db.Uuid
  action         String    @db.VarChar(100)
  entityType     String?   @map("entity_type") @db.VarChar(50)
  entityId       String?   @map("entity_id") @db.Uuid
  description    String?   @db.Text
  ipAddress      String?   @map("ip_address") @db.Inet
  userAgent      String?   @map("user_agent") @db.Text
  requestMethod  String?   @map("request_method") @db.VarChar(10)
  requestPath    String?   @map("request_path") @db.Text
  requestBody    Json?     @map("request_body") @db.JsonB
  responseStatus Int?      @map("response_status")
  metadata       Json?     @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agmSession     AgmSession?   @relation(fields: [agmSessionId], references: [id], onDelete: SetNull)
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model MeetingAttendance {
  id              String    @id @default(uuid()) @db.Uuid
  agmSessionId    String    @map("agm_session_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  checkInTime     DateTime  @default(now()) @map("check_in_time") @db.Timestamptz(6)
  checkOutTime    DateTime? @map("check_out_time") @db.Timestamptz(6)
  durationMinutes Int?      @map("duration_minutes")
  ipAddress       String?   @map("ip_address") @db.Inet
  deviceInfo      Json?     @map("device_info") @db.JsonB

  agmSession      AgmSession @relation(fields: [agmSessionId], references: [id], onDelete: Cascade)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agmSessionId, userId])
  @@map("meeting_attendance")
}

model VoteVerificationToken {
  id            String   @id @default(uuid()) @db.Uuid
  voteId        String?  @map("vote_id") @db.Uuid
  voteType      String   @map("vote_type") @db.VarChar(50)
  tokenHash     String   @unique @map("token_hash") @db.Text
  verificationCode String @unique @map("verification_code") @db.VarChar(20)
  blockchainTxHash String? @map("blockchain_tx_hash") @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("vote_verification_tokens")
}

model VotingPattern {
  id                    String   @id @default(uuid()) @db.Uuid
  organizationId        String   @map("organization_id") @db.Uuid
  userId                String   @unique @map("user_id") @db.Uuid
  totalMeetingsAttended Int      @default(0) @map("total_meetings_attended")
  totalVotesCast        Int      @default(0) @map("total_votes_cast")
  totalProxiesGiven     Int      @default(0) @map("total_proxies_given")
  totalProxiesReceived  Int      @default(0) @map("total_proxies_received")
  participationRate     Decimal  @default(0.00) @map("participation_rate") @db.Decimal(5, 2)
  lastVoteAt            DateTime? @map("last_vote_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("voting_patterns")
}

model ReportHistory {
  id            String   @id @default(uuid()) @db.Uuid
  agmSessionId  String   @map("agm_session_id") @db.Uuid
  reportType    String   @map("report_type") @db.VarChar(50)
  fileUrl       String?  @map("file_url") @db.Text
  generatedBy   String?  @map("generated_by") @db.Uuid
  fileSizeBytes BigInt?  @map("file_size_bytes")
  generatedAt   DateTime @default(now()) @map("generated_at") @db.Timestamptz(6)

  agmSession    AgmSession @relation(fields: [agmSessionId], references: [id], onDelete: Cascade)

  @@map("report_history")
}

// =====================================================
// SYSTEM CONFIGURATION
// =====================================================

model FeatureFlag {
  id                      String   @id @default(uuid()) @db.Uuid
  flagName                String   @unique @map("flag_name") @db.VarChar(100)
  description             String?  @db.Text
  isEnabled               Boolean  @default(false) @map("is_enabled")
  enabledForOrganizations String[] @map("enabled_for_organizations") @db.Uuid
  enabledForUsers         String[] @map("enabled_for_users") @db.Uuid
  rolloutPercentage       Int      @default(0) @map("rollout_percentage")
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("feature_flags")
}

model SystemSetting {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(100)
  value       String   @db.Text
  valueType   String   @default("string") @map("value_type") @db.VarChar(50)
  description String?  @db.Text
  isSecret    Boolean  @default(false) @map("is_secret")
  updatedBy   String?  @map("updated_by") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("system_settings")
}

model EmailTemplate {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  templateName   String   @map("template_name") @db.VarChar(100)
  subject        String   @db.VarChar(500)
  bodyHtml       String   @map("body_html") @db.Text
  bodyText       String?  @map("body_text") @db.Text
  variables      Json?    @db.JsonB
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, templateName])
  @@map("email_templates")
}
